{
  "title": "Intellidog -- Event Watchdog",
  "uid": "intellidog-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["intellidog", "observability", "sre"],
  "panels": [
    {
      "id": 1,
      "title": "Events Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, COUNT(*) as events FROM events WHERE $__timeFilter(timestamp) GROUP BY strftime('%Y-%m-%dT%H:%M:00Z', timestamp) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as value FROM alerts WHERE status='active'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "LLM Anomalies (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as value FROM alerts WHERE source='llm' AND fired_at >= datetime('now', '-1 hour')",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Events (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as value FROM events WHERE timestamp >= datetime('now', '-1 hour')",
          "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 5,
      "title": "Error Events (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as value FROM events WHERE timestamp >= datetime('now', '-1 hour') AND (severity='critical' OR severity='high')",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Severity Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT severity as metric, COUNT(*) as value FROM events WHERE timestamp >= datetime('now', '-1 hour') GROUP BY severity",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Top Sources by Event Count",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT source as metric, COUNT(*) as value FROM events WHERE timestamp >= datetime('now', '-1 hour') GROUP BY source ORDER BY value DESC LIMIT 10",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 8,
      "title": "Recent Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT fired_at, rule_name, severity, status, source, message FROM alerts ORDER BY fired_at DESC LIMIT 20",
          "format": "table"
        }
      ]
    },
    {
      "id": 9,
      "title": "P99 Latency (ms) Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, CAST(json_extract(payload, '$.duration_ms') AS REAL) as p99_ms FROM events WHERE $__timeFilter(timestamp) AND json_extract(payload, '$.duration_ms') IS NOT NULL ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "LLM Anomaly Feed",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Intellidog SQLite",
      "targets": [
        {
          "rawSql": "SELECT fired_at, rule_name, severity, message FROM alerts WHERE source='llm' ORDER BY fired_at DESC LIMIT 20",
          "format": "table"
        }
      ]
    }
  ]
}
